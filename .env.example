# Binance API
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# SendGrid (para envío de emails)
SENDGRID_API_KEY=your_sendgrid_api_key_here
EMAIL_FROM=your_bot_email@example.com
EMAIL_TO=your_personal_email@example.com

# Modo de ejecución
# "paper" = simulación (no ejecuta órdenes reales)
# "live"  = operaciones reales con dinero
TRADING_MODE=paper
